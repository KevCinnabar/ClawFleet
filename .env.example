# ==========================================
# ClawFleet 环境变量配置示例
# ==========================================
#
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填入你的实际配置值
# 3. 不要将 .env 文件提交到版本控制系统
#
# 最后更新: 2026-03-09
# ==========================================

# ==========================================
# OpenAI API 配置（必需）
# ==========================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ==========================================
# OpenClaw Gateway 配置
# ==========================================
# 固定 token，用于访问 Canvas UI 和 WebSocket
# bind=lan 时必须设置
OPENCLAW_GATEWAY_TOKEN=clawfleet-dev-token-2026

# ==========================================
# Notion 集成配置（可选）
# ==========================================
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_WORKSPACE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PRD_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TASKS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# GitHub 集成配置（推荐）
# ==========================================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPOSITORY=your-org/clawfleet
GITHUB_PROJECT_ID=123

# ==========================================
# WhatsApp 集成配置（可选）
# ==========================================
WHATSAPP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_ID=xxxxxxxxxxxxxxxx
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token

# ==========================================
# 飞书集成配置（可选）
# ==========================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# 向量数据库配置（可选，用于记忆持久化）
# ==========================================
# Pinecone
PINECONE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_ENVIRONMENT=production
PINECONE_INDEX_NAME=clawfleet-memory

# ==========================================
# Email 配置（可选）
# ==========================================
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM_NAME=ClawFleet
EMAIL_FROM_ADDRESS=clawfleet@your-domain.com

# ==========================================
# Slack 集成配置（可选）
# ==========================================
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# 应用配置
# ==========================================
NODE_ENV=production
LOG_LEVEL=info

# Manager Agent
MANAGER_PORT=3001
MANAGER_HOST=0.0.0.0

# Developer Agent
DEVELOPER_PORT=3002
DEVELOPER_HOST=0.0.0.0

# ==========================================
# OpenClaw 配置
# ==========================================
OPENCLAW_HOME=/data/.openclaw
OPENCLAW_WORKSPACE=/data/workspace

# ==========================================
# 安全配置（可选）
# ==========================================
JWT_SECRET=change-this-to-a-random-secret-in-production
API_ACCESS_KEY=your-api-access-key

# ==========================================
# 监控配置（可选）
# ==========================================
# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=clawfleet

# Datadog
# DD_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DD_SITE=datadoghq.com

# ==========================================
# 云服务配置（可选）
# ==========================================
# AWS
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_REGION=us-west-2

# 阿里云
# ALIYUN_ACCESS_KEY_ID=LTAIxxxxxxxxxxxxxxxx
# ALIYUN_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# 备注
# ==========================================
#
# 安全提示：
# - 定期轮换所有密钥和 token
# - 使用强密码生成器生成随机密钥
# - 不要在代码中硬编码任何密钥
# - 为不同环境使用不同的密钥
#
# ==========================================

