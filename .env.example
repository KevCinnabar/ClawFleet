# ==========================================
# ClawFleet 环境变量配置
# ==========================================
#
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填入你的实际配置值
# 3. 不要将 .env 文件提交到版本控制系统
#
# 最后更新: 2026-03-12
# ==========================================

# ------------------------------------------
# OpenAI API 配置（必需）
# ------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ------------------------------------------
# OpenClaw Gateway 配置（必需）
# ------------------------------------------
# 固定 token，用于访问 Canvas UI 和 WebSocket
# bind=lan 时必须设置
OPENCLAW_GATEWAY_TOKEN=clawfleet-dev-token-2026

# ------------------------------------------
# Notion 集成配置（可选）
# ------------------------------------------
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_WORKSPACE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PRD_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TASKS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------
# GitHub 集成配置（推荐）
# ------------------------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPOSITORY=your-org/clawfleet

# ------------------------------------------
# Slack 集成配置（可选）
# ------------------------------------------
# Bot Token: Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# App Token: Slack App → Basic Information → App-Level Tokens (需要 connections:write scope)
# ⚠️ Socket Mode 必须有此 token，否则 Slack channel 状态为 "not configured"
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Signing Secret: Slack App → Basic Information → App Credentials
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------
# 应用配置
# ------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
