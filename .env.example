# ==========================================
# ClawFleet 环境变量模板
# ==========================================
#
# 使用方式：
#   cp .env.example agents/manager/.env
#   cp .env.example agents/developer/.env
#   然后分别编辑，填入真实值。
#
# 每个 Agent 拥有独立的 .env：
#   agents/manager/.env    ← Manager 专属
#   agents/developer/.env  ← Developer 专属
#
# ⚠️ Slack Token 必须不同——每个 Agent 需要独立的 Slack App。
# ==========================================

# ------------------------------------------
# OpenAI API（必需）
# ------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# ------------------------------------------
# Model（可按角色调整）
#   Manager 推荐: gpt-4o-mini（侧重沟通）
#   Developer 推荐: gpt-4.1-mini（侧重代码）
# ------------------------------------------
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-4.1-mini
OPENCLAW_MAX_CONCURRENT=2

# ------------------------------------------
# OpenClaw Gateway（必需）
# ------------------------------------------
OPENCLAW_GATEWAY_TOKEN=clawfleet-dev-token-2026

# ------------------------------------------
# Notion（可选，Manager 和 Developer 可共用）
# ------------------------------------------
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_PRD_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ------------------------------------------
# GitHub（推荐，Manager 和 Developer 可共用）
# ------------------------------------------
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPOSITORY=your-org/ClawFleet

# ------------------------------------------
# Slack（⚠️ 每个 Agent 必须使用不同的 Slack App）
# 创建 Slack App: https://api.slack.com/apps → Create New App
# ------------------------------------------
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack 频道白名单（可选，逗号分隔 Channel ID）
# 不设置 = 响应所有被邀请到的频道
# 获取 Channel ID：Slack 中右键频道 → View channel details → 底部
# SLACK_ALLOWED_CHANNELS=C07XXXXXXXX,C07YYYYYYYY

